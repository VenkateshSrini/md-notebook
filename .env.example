# ── Anthropic (default provider) ──────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_CHAT_MODEL_ID=claude-sonnet-4-5-20250929

# ── Provider selection ─────────────────────────────────────────────────────────
# Options: anthropic (default) | bedrock
LLM_PROVIDER=anthropic

# ── AWS Bedrock (set LLM_PROVIDER=bedrock to activate) ────────────────────────
# BEDROCK_CHAT_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0
# BEDROCK_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
# AWS_SESSION_TOKEN=your-session-token   # Optional — only needed for temp creds

# ── REST API server (main_api.py) ──────────────────────────────────────────────
# Port the FastAPI/uvicorn server listens on.
PORT=8000

# ── Gradio web UI server (main_ui.py) ─────────────────────────────────────────
# Host to bind the Gradio server to.
# Use 0.0.0.0 to allow connections from other machines on your network,
# or 127.0.0.1 to restrict to localhost only.
UI_HOST=0.0.0.0
# Port the Gradio UI listens on.
# Must differ from PORT if running both the REST API and UI simultaneously.
UI_PORT=7860